DJANGO_ENV=development
DEBUG=true
SECRET_KEY=replace-this-in-production
ALLOWED_HOSTS=127.0.0.1,localhost,0.0.0.0

# CORS / CSRF
CORS_ALLOW_ALL_ORIGINS=true
CORS_ALLOWED_ORIGINS=
CSRF_TRUSTED_ORIGINS=

# DB
DB_ENGINE=django.db.backends.sqlite3
DB_NAME=db.sqlite3
DB_USER=
DB_PASSWORD=
DB_HOST=localhost
DB_PORT=

# AI / LLM — DeepSeek V4 原生 API
# 申请 API Key: https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=
LLM_BASE_URL=https://api.deepseek.com
LLM_MODEL=deepseek-v4-pro
LLM_REQUEST_TIMEOUT_SECONDS=120
LLM_REQUEST_MAX_RETRIES=1

# 各任务类型模型覆盖（可选）
# 策略：flash 用于对话/解析等快速任务，pro 用于出题/评分（pro 默认会思考）
# AI_MODEL_CHAT=deepseek-v4-flash            # 对话（快速响应）
# AI_MODEL_GENERATE_AUTHOR=deepseek-v4-pro   # 出题（pro，无思考）
# AI_MODEL_GENERATE_REVIEWER=deepseek-v4-pro # 审核（pro，思考模式 high）
# AI_MODEL_GENERATE_CLASSIFIER=deepseek-v4-flash  # 分类（flash）
# AI_MODEL_GRADE_SUBJECTIVE=deepseek-v4-pro  # 主观题评分（pro，思考模式 high）
# AI_MODEL_ESSAY_GRADE=deepseek-v4-pro       # 作文评分（pro，思考模式 max）
# AI_MODEL_GENERATE_ANSWER=deepseek-v4-flash # 答案解析（flash）
# AI_MODEL_PARSE_TEXT=deepseek-v4-flash      # 文本解析（flash）
# AI_MODEL_SCHEMA_REPAIR=deepseek-v4-flash   # JSON 修复（flash）

# Cache / Queue
REDIS_URL=redis://127.0.0.1:6379/0
CHANNEL_LAYER_REDIS_URL=redis://127.0.0.1:6379/0
CELERY_BROKER_URL=redis://127.0.0.1:6379/0
CELERY_RESULT_BACKEND=redis://127.0.0.1:6379/0

# Optional runtime controls
LOG_LEVEL=INFO
ONLINE_USER_ACTIVE_WINDOW_SECONDS=300
AI_BULK_GENERATE_MAX_PER_REQUEST=3
AI_BULK_GENERATE_CONCURRENCY=4

# ELO / Leaderboard
ELO_K_FACTOR=32
ELO_INITIAL_BONUS=200
ELO_INITIAL_BONUS_THRESHOLD=0.8
LEADERBOARD_SIZE=50
ELO_RESET_MAX_COUNT=1

# FSRS / Study Planner
STUDY_MINUTES_PER_QUESTION=2.8
STUDY_COOLDOWN_MINUTES=30

# AI Circuit Breaker
AI_CB_FAILURE_THRESHOLD=5
AI_CB_RECOVERY_TIMEOUT=300
AI_CB_WINDOW_TIMEOUT=60

# GIPHY
GIPHY_API_KEY=

# Email — Gmail SMTP
# 重要：Gmail 需要使用「应用专用密码」(App Password)，不是邮箱密码！
# 获取步骤：
#   1. 开启两步验证：https://myaccount.google.com/security
#   2. 访问 https://myaccount.google.com/apppasswords
#   3. 选择「邮件」→「其他」，名称填 "UniMind"
#   4. 复制 16 位密码（去掉空格）填入下方
#   5. 开发环境可改用 console 后端：EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=true
EMAIL_HOST_USER=your-email@example.com
EMAIL_HOST_PASSWORD=your-gmail-app-password
EMAIL_NOREPLY_ADDRESS=your-email@example.com

# ASR 语音转文字
ASR_DEFAULT_PROVIDER=vosk
VOSK_MODEL_PATH=/path/to/vosk-model-small-cn-0.22
