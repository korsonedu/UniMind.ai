DJANGO_ENV=development
DEBUG=true
SECRET_KEY=replace-this-in-production
ALLOWED_HOSTS=127.0.0.1,localhost,0.0.0.0

# CORS / CSRF
CORS_ALLOW_ALL_ORIGINS=true
CORS_ALLOWED_ORIGINS=
CSRF_TRUSTED_ORIGINS=

# DB
DB_ENGINE=django.db.backends.sqlite3
DB_NAME=db.sqlite3
DB_USER=
DB_PASSWORD=
DB_HOST=localhost
DB_PORT=

# ── AI / LLM ──
LLM_API_KEY=

# 以下均可选，不设则用 config.py 内置默认值
# LLM_BASE_URL=    # 覆盖 API 地址
# LLM_MODEL=        # 全局模型覆盖
# AI_MODEL_FAST=    # 轻量任务分级（对话/分类/解析/schema修复）
# AI_MODEL_PRO=     # 重量任务分级（评审/判分/知识树生成）

# 单任务精确覆盖（优先级最高，极少需要）
# AI_MODEL_CHAT=  AI_MODEL_GENERATE_AUTHOR=  AI_MODEL_GENERATE_REVIEWER=
# AI_MODEL_GENERATE_CLASSIFIER=  AI_MODEL_GRADE_SUBJECTIVE=
# AI_MODEL_GENERATE_ANSWER=  AI_MODEL_PARSE_TEXT=
# AI_MODEL_SCHEMA_REPAIR=  AI_MODEL_GENERATE_KNOWLEDGE_TREE=

LLM_REQUEST_TIMEOUT_SECONDS=120
LLM_REQUEST_MAX_RETRIES=1

# Cache / Queue — 生产环境必须设置密码，格式: redis://:password@host:port/db
REDIS_URL=redis://127.0.0.1:6379/0
CHANNEL_LAYER_REDIS_URL=redis://127.0.0.1:6379/0
CELERY_BROKER_URL=redis://127.0.0.1:6379/0
CELERY_RESULT_BACKEND=redis://127.0.0.1:6379/0

# Optional runtime controls
LOG_LEVEL=INFO
ONLINE_USER_ACTIVE_WINDOW_SECONDS=300
AI_BULK_GENERATE_MAX_PER_REQUEST=3
AI_BULK_GENERATE_CONCURRENCY=4

# ELO / Leaderboard
ELO_K_FACTOR=32
ELO_INITIAL_BONUS=200
ELO_INITIAL_BONUS_THRESHOLD=0.8
LEADERBOARD_SIZE=50
ELO_RESET_MAX_COUNT=1

# FSRS / Study Planner
STUDY_MINUTES_PER_QUESTION=2.8
STUDY_COOLDOWN_MINUTES=30

# AI Circuit Breaker
AI_CB_FAILURE_THRESHOLD=5
AI_CB_RECOVERY_TIMEOUT=300
AI_CB_WINDOW_TIMEOUT=60

# 加密密钥（Fernet AES，用于加密微信/支付宝支付密钥等敏感字段）
# 可选 — 不设置则从 SECRET_KEY 自动派生（SHA256 → base64）
ENCRYPTION_KEY=

# ASR — 智谱 GLM 语音转文字
ASR_DEFAULT_PROVIDER=glm_asr
GLM_ASR_API_KEY=

# ── Payment Gateways ──
# Stripe (国际信用卡)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# 微信支付 APIv3
WECHAT_MCH_ID=
WECHAT_API_V3_KEY=
WECHAT_CERT_SERIAL=
WECHAT_PRIVATE_KEY_PATH=
WECHAT_APP_ID=
WECHAT_NOTIFY_URL=
# 支付宝
ALIPAY_APP_ID=
ALIPAY_PRIVATE_KEY=
ALIPAY_PUBLIC_KEY=
ALIPAY_NOTIFY_URL=
ALIPAY_RETURN_URL=

# GIPHY
GIPHY_API_KEY=

# Email — Resend HTTP API
# 申请: https://resend.com/api-keys
EMAIL_BACKEND=core.email_service.ResendEmailBackend
RESEND_API_KEY=re_xxx
EMAIL_NOREPLY_ADDRESS=noreply@yourdomain.com
